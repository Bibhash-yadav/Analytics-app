generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)

  reports   Report[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Report {
  id          String   @id @default(cuid())
  title       String

  revenue     Float
  visitors    Int
  conversions Int

  userId      String
  user        User @relation(fields: [userId], references: [id])

  createdAt   DateTime @default(now())
}